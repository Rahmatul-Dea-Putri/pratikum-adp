# Input deret bilangan 
data = input("Masukkan deret bilangan bulat: ")
deret = []
for x in data.split():
    deret.append(int(x))


# 1. Hitung jumlah positif, negatif, dan nol
positif = 0
negatif = 0
nol = 0

for angka in deret:
    if angka > 0:
        positif += 1
    elif angka < 0:
        negatif += 1
    else:
        nol += 1

# 2. Hitung perubahan tanda
perubahan_tanda = 0

for i in range(len(deret) - 1):
    if deret[i] * deret[i + 1] < 0:
        perubahan_tanda += 1

# 3. Cek pola berulang
pola_berulang = False

for i in range(len(deret)):
    for j in range(i + 1, len(deret)):
        if deret[i] == deret[j]:
            pola_berulang = True

# 4. Tentukan status utama
status = "Normal"

for i in range(len(deret) - 2):
    # Manipulator Pola
    if deret[i] < 0 and deret[i+1] > 0 and deret[i+2] < 0:
        status = "Manipulator Pola"

    # Risiko Terselubung
    elif negatif > positif and nol > 0:
        status = "Risiko Terselubung"

    # Pola Campuran
    elif perubahan_tanda > 2 and pola_berulang:
        status = "Pola Campuran"

# OUTPUT
print("\nHasil Analisis:")
print("Jumlah Positif:", positif)
print("Jumlah Negatif:", negatif)
print("Jumlah Nol:", nol)
print("Perubahan Tanda:", perubahan_tanda)
print("Ada Pola Berulang:", pola_berulang)
print("Status Utama:", status)
